{
  "rules": {
    "games": {
      "$gameCode": {
        ".read": "auth != null && (!data.exists() || auth.uid === root.child('games/' + $gameCode + '/host').val())",
        ".write": "auth != null && !data.exists() && newData.child('host').val() === auth.uid",

        "state": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        },

        "roles": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        },

        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('games/' + $gameCode + '/host').val())"
          }
        },

        "private": {
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || auth.uid === root.child('games/' + $gameCode + '/host').val())",
            ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
          }
        },

        "nightActions": {
          ".read": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        },

        "tempFeedback": {
          ".read": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        },

        "dayActions": {
          ".read": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        },

        "log": {
          ".read": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()",
          ".write": "auth != null && auth.uid === root.child('games/' + $gameCode + '/host').val()"
        }
      }
    }
  }
}
